{
  "approvals": {
    "file_deletion": true,
    "database_changes": true,
    "plugin_installation": true,
    "dependency_installation": true,
    "git_commits": true,
    "git_pushes": true,
    "pull_request_creation": true,
    "production_changes": true,
    "sending_messages": true,
    "risky_commands": true
  },
  "ui": {
    "toast_position": "top-right"
  },
  "escalation": {
    "enabled": false,
    "teams_enabled": true,
    "find_hub_enabled": true,
    "owner_phone_enabled": false,
    "backup_phone_enabled": false,
    "quiet_hours_start": "22:00",
    "quiet_hours_end": "08:00",
    "teams_delay_minutes": 5,
    "owner_phone_delay_minutes": 10,
    "backup_phone_delay_minutes": 15,
    "max_attempts": 2,
    "acknowledgement_words": ["ack", "seen", "handled"]
  },
  "codex": {
    "default_sandbox_for_analysis": "read-only",
    "default_sandbox_for_edits": "workspace-write",
    "use_json_output": false
