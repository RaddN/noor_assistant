[
  {
    "id": "greeting",
    "name": "Greeting",
    "enabled": true,
    "trigger_logic": "any",
    "audience": {
      "scope": "everyone",
      "contacts": []
    },
    "triggers": [
      {
        "type": "message",
        "match": "regex",
        "value": "^\\s*(hi|hello|hey|assalamu alaikum|assalamualaikum|salam)\\b"
      }
    ],
    "actions": [
      {
        "type": "reply",
        "text": "Hello. I am Noor, Raihan Hossain's assistant. Send a supported command or question and I will handle it."
      }
    ]
  },
